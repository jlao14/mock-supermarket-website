<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ABC Supermarkets - Fresh Products Daily</title>
    <link rel="stylesheet" href="mainstyles.css">
</head>
<body>
    <header class="header">
        <div class="top-bar">
            <div class="logo-section">
                <div><img src="ABC Supermarket Logo.png" alt="ABC Supermarkets Logo" class="logo-circle"></div>
                <div class="logo-text">
                    <h1>ABC Supermarket</h1>
                    <p>Quality Guaranteed</p>
                </div>
            </div>
            <div class="user_actions">
                <a href="loginpage.html">Login</a>
                <a href="registerpage.html">Register</a>
                <a href="cartpage.html" class="cart">Cart</a>
            </div>
        </div>
        <nav class="main-nav">
            <ul class="nav-links">
                <li><a href="homepage.html">Home</a></li>
                <li><a href="freshproduce.html">Fresh Produce</a></li>
                <li><a href="meatpoultry.html">Meat and Poultry</a></li>
                <li><a href="householditems.html">Cleaning and Household</a></li>
                <li><a href="personalcare.html">Beauty and Personal Care</a></li>
            </ul>
        </nav>
    </header>

    <main class="main-content">
        <section class="cart-section">
            <h2>Your Shopping Cart</h2>

            <!-- Section is left empty so items can be dynamically added via localStorage and javascript -->

            <div class="cart-items">
            </div>

            <!-- A cart message is displayed if cart is empty and user wishes to checkout-->
            <div id="cartMessage" style="text-align: center; color: #dc3545; margin-top: 20px; font-weight: bold;"></div>

            <div class="cart-summary">
                <div class="summary-line">
                    <span>Total Items:</span>
                    <span id="totalNumItems">0</span>
                </div>
                <div class="summary-line">
                    <span>Subtotal:</span>
                    <span id="currentCartSubtotal">$0.00</span>
                </div>
                <div class="summary-line">
                    <span>Shipping:</span>
                    <span>Free</span>
                </div>
                <div class="summary-line total-line">
                    <span>Grand Total:</span>
                    <span id="grandCartTotal">$0.00</span>
                </div>
            </div>

            <div class="cart-actions">
                <a href="homepage.html" class="continue-shopping-btn">Continue Shopping</a>
                <button class="proceed-to-checkout-btn">Proceed to Checkout</button>
            </div>
        </section>
    </main>


    <footer class="footer">
        <div class="footer-content">
            <div class="footer-section">
                <h2>ABC Supermarkets</h2>
                <p>Here at ABC Supermarkets we guarantee quality and freshness in every product at a price you can afford.</p>
            </div>
            <div class="footer-section">
                <h3>Quick Links</h3>
                <ul>
                    <li><a href="homepage.html">Home</a></li>
                    <li><a href="loginpage.html">Login</a></li>
                    <li><a href="registerpage.html">Register</a></li>
                    <li><a href="#">Cart</a></li>
                </ul>
            </div>
            <div class="footer-section">
                <h3>Customer Service</h3>
                <ul>
                    <li><p>Need Help?</p></li>
                    <li><p>Ask us a question!</p></li>
                    <li><a onclick="askQuery()">Click Here</a></li>
                    <script>
                        function askQuery() {
                            const question = prompt("Please enter your query:");
                            if (question) {
                                alert("Thank you for your query! We will get back to you soon.");
                            } else {
                                alert("No query entered.");
                            }
                        }
                    </script>
                </ul>
            </div>
            <div class="footer-section">
                <h3>Contact Info</h3>
                <address>
                    <p>Dubai, United Arab Emirates</p>
                    <a href="tel:+042124623">04 212 4623</a><br>
                    <a href="mailto:contactus@abcsupermarkets.com">contactus@abcsupermarkets.com</a>
                </address>
                <p>Everyday 7:00 AM - 10:00 PM</p>
            </div>
        </div>
    </footer>

    <script src="products.js"></script>
    <script>
        // All relative classes and attributes are selected and assigned to a variable
        document.addEventListener('DOMContentLoaded', () => {
            const cartItemsContainer = document.querySelector('.cart-items');
            const totalNumItemsSpan = document.getElementById('totalNumItems');
            const currentCartSubtotalSpan = document.getElementById('currentCartSubtotal');
            const grandCartTotalSpan = document.getElementById('grandCartTotal');
            const proceedToCheckoutBtn = document.querySelector('.proceed-to-checkout-btn');
            const cartMessageDiv = document.getElementById('cartMessage'); 

            let cart = []; // This is the global cart array for this page

            function getCart() {
                const cartData = localStorage.getItem('cart');
                return cartData ? JSON.parse(cartData) : [];
            }
            // Cart array is immediately updated accordingly
            function saveCart(updatedCart) {
                localStorage.setItem('cart', JSON.stringify(updatedCart));
                cart = updatedCart; 
            }

            function findProductById(productId) {
                return products.find(p => p.id === productId);
            }

            // This function ensures that the cart page renders appropriately and stays up to date
            function renderCart() {
                cart = getCart(); 
                cartItemsContainer.innerHTML = ''; 
                cartMessageDiv.textContent = ''; 

                if (cart.length === 0) {
                    cartItemsContainer.innerHTML = '<p style="text-align: center; padding: 20px; color: #555;">Your cart is empty.</p>';
                    updateCartSummary();
                    return;
                }
                // Each item in the cart is looped through and checked if they are there in the products list, 
                // then all relevant information regarding the product is added such as price, name , etc.
                cart.forEach(item => {
                    const product = findProductById(item.productId);
                    if (product) {
                        const itemSubtotal = (product.price * item.quantity).toFixed(2);
                        const cartItemDiv = document.createElement('div');
                        cartItemDiv.classList.add('cart-item');
                        cartItemDiv.setAttribute('data-product-id', product.id);

                        cartItemDiv.innerHTML = `
                            <img src="${product.image}" alt="${product.name}" class="item-image">
                            <div class="item-details">
                                <h3>${product.name}</h3>
                                <p class="item-price">AED ${product.price.toFixed(2)}</p>
                            </div>
                            <div class="item-quantity">
                                <button class="quantity-btn minus-btn" data-product-id="${product.id}">-</button>
                                <input type="number" value="${item.quantity}" min="1" class="quantity-input" data-product-id="${product.id}">
                                <button class="quantity-btn plus-btn" data-product-id="${product.id}">+</button>
                            </div>
                            <span class="item-subtotal">AED ${itemSubtotal}</span>
                            <button class="remove-item-btn" data-product-id="${product.id}">Remove</button>
                        `;
                        cartItemsContainer.appendChild(cartItemDiv);
                    }
                });
                updateCartSummary();
                attachCartEventListeners(); 
            }

            // Cart summary is then updated according to data found regarding cart
            function updateCartSummary() {
                let totalItems = 0;
                let subtotal = 0;

                cart.forEach(item => {
                    const product = findProductById(item.productId);
                    if (product) {
                        totalItems += item.quantity;
                        subtotal += product.price * item.quantity;
                    }
                });

                totalNumItemsSpan.textContent = totalItems;
                currentCartSubtotalSpan.textContent = `AED ${subtotal.toFixed(2)}`;
                grandCartTotalSpan.textContent = `AED ${subtotal.toFixed(2)}`;
            }
            // This function attaches event listeners to the quantity buttons and allows for adding and removing of product quantity
            function attachCartEventListeners() {
                document.querySelectorAll('.quantity-btn').forEach(button => {
                    button.onclick = null; 
                    button.onclick = (event) => {
                        const productId = event.target.dataset.productId;
                        const input = document.querySelector(`.quantity-input[data-product-id="${productId}"]`);
                        let currentQuantity = parseInt(input.value);

                        if (event.target.classList.contains('plus-btn')) {
                            currentQuantity++;
                        } else if (event.target.classList.contains('minus-btn') && currentQuantity > 1) {
                            currentQuantity--;
                        }

                        updateCartItemQuantity(productId, currentQuantity);
                    };
                });
                // This section adds a listener for when the user wishes to directly change a quantity by writing a new number
                document.querySelectorAll('.quantity-input').forEach(input => {
                    input.onchange = null; 
                    input.onchange = (event) => {
                        const productId = event.target.dataset.productId;
                        let newQuantity = parseInt(event.target.value);

                        if (isNaN(newQuantity) || newQuantity < 1) {
                            newQuantity = 1; 
                            event.target.value = 1;
                        }
                        updateCartItemQuantity(productId, newQuantity);
                    };
                });

                // This section adds a listener for the remove button and allows for products to be removed from the cart when needed
                document.querySelectorAll('.remove-item-btn').forEach(button => {
                    button.onclick = null; 
                    button.onclick = (event) => {
                        const productId = event.target.dataset.productId;
                        removeCartItem(productId);
                    };
                });
            }

            // This function updates the quantity of a specific product in the cart and saves it
            function updateCartItemQuantity(productId, newQuantity) {
                let currentCart = getCart();
                const itemIndex = currentCart.findIndex(item => item.productId === productId);

                if (itemIndex > -1) {
                    currentCart[itemIndex].quantity = newQuantity;
                    saveCart(currentCart);
                    renderCart(); 
                }
            }
            // This function removes a selected cart item from the cart 
            function removeCartItem(productId) {
                let currentCart = getCart(); 
                const updatedCart = currentCart.filter(item => item.productId !== productId);
                saveCart(updatedCart);
                renderCart(); 
            }

            // After page finishes loading this function is called immediately to render the page
            renderCart();

            // Ensures functionality of the checkout button
            proceedToCheckoutBtn.addEventListener('click', () => {
                cart = getCart();
                if (cart.length > 0) {
                    // If there are items in the cart then user is redirected to the cart page
                    window.location.href = 'checkoutpage.html';
                } else {
                    // If cart is empty then message is shown
                    cartMessageDiv.textContent = 'Your cart is empty. Please add items before checking out.';
                }
            });
        });
    </script>
</body>
</html>
